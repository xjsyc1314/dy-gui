{
  "description": "Shared proxy validation samples for Property C parity tests (TS <-> Python). Keep the schema stable; update _is_valid_proxy in server/app.py and isValidProxy in Settings.tsx together when adding new patterns.",
  "samples": [
    { "input": "", "expected": { "isValid": true } },
    { "input": "http://127.0.0.1:7890", "expected": { "isValid": true, "scheme": "http" } },
    { "input": "http://proxy.example.com:8080", "expected": { "isValid": true, "scheme": "http" } },
    { "input": "http://user:pass@proxy.example.com:8080", "expected": { "isValid": true, "scheme": "http" } },
    { "input": "http://10.0.0.1:3128", "expected": { "isValid": true, "scheme": "http" } },
    { "input": "http://[::1]:8080", "expected": { "isValid": true, "scheme": "http" } },
    { "input": "http://localhost:7890", "expected": { "isValid": true, "scheme": "http" } },
    { "input": "http://user:pass@127.0.0.1:8080", "expected": { "isValid": true, "scheme": "http" } },
    { "input": "http://[::1]", "expected": { "isValid": true, "scheme": "http" } },
    { "input": "https://proxy.example.com", "expected": { "isValid": true, "scheme": "https" } },
    { "input": "https://secure-proxy.internal:8443", "expected": { "isValid": true, "scheme": "https" } },
    { "input": "https://proxy.corp.example.com:443", "expected": { "isValid": true, "scheme": "https" } },
    { "input": "https://127.0.0.1:8443", "expected": { "isValid": true, "scheme": "https" } },
    { "input": "socks5://127.0.0.1:1080", "expected": { "isValid": true, "scheme": "socks5" } },
    { "input": "socks5://user@proxy:1080", "expected": { "isValid": true, "scheme": "socks5" } },
    { "input": "socks5://127.0.0.1", "expected": { "isValid": true, "scheme": "socks5" } },
    { "input": "socks5h://dnsresolver:1080", "expected": { "isValid": true, "scheme": "socks5h" } },
    { "input": "socks5h://[fe80::1]:1080", "expected": { "isValid": true, "scheme": "socks5h" } },
    { "input": "socks5h://example.com", "expected": { "isValid": true, "scheme": "socks5h" } },
    { "input": "ftp://proxy.example.com", "expected": { "isValid": false } },
    { "input": "ws://example.com", "expected": { "isValid": false } },
    { "input": "socks://127.0.0.1", "expected": { "isValid": false } },
    { "input": "socks4://127.0.0.1", "expected": { "isValid": false } },
    { "input": "tcp://127.0.0.1", "expected": { "isValid": false } },
    { "input": "rsync://example.com", "expected": { "isValid": false } },
    { "input": "javascript:alert(1)", "expected": { "isValid": false } },
    { "input": "file:///tmp/x", "expected": { "isValid": false } },
    { "input": "proxy.example.com:8080", "expected": { "isValid": false } },
    { "input": "127.0.0.1:7890", "expected": { "isValid": false } },
    { "input": "example.com", "expected": { "isValid": false } },
    { "input": "http://", "expected": { "isValid": false } },
    { "input": "https://", "expected": { "isValid": false } },
    { "input": "socks5://", "expected": { "isValid": false } },
    { "input": "socks5h://", "expected": { "isValid": false } },
    { "input": "http:// ", "expected": { "isValid": false } },
    { "input": "http://   ", "expected": { "isValid": false } },
    { "input": "   ", "expected": { "isValid": false } },
    { "input": "\t", "expected": { "isValid": false } },
    { "input": "\n", "expected": { "isValid": false } },
    { "input": "http:/missing-slash.com", "expected": { "isValid": false } },
    { "input": "://no-scheme.com", "expected": { "isValid": false } },
    { "input": "http//missing-colon.com", "expected": { "isValid": false } },
    { "input": "htp://example.com", "expected": { "isValid": false } },
    { "input": " http://example.com ", "expected": { "isValid": false } },
    { "input": "HTTP://EXAMPLE.COM", "expected": { "isValid": false } },
    { "input": "HtTp://example.com", "expected": { "isValid": false } }
  ]
}
